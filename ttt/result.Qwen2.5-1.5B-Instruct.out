```python
# Randomly select a non-winning move
import numpy as np

def get_random_non_winning_move(board):
    # Convert board string to list of lists
    board_list = [list(row) for row in board.split()]
    
    # Find indices of empty spaces
    empty_indices = [(i, j) for i in range(3) for j in range(3) if board_list[i][j] == '-']
    
    # Select a random non-winning move
    while True:
        index = np.random.choice(len(empty_indices))
        row, col = empty_indices[index]
        
        # Check if it leads to a win
        if not check_win(board_list, row, col, 'O'):
            return row, col
    
    return None

def check_win(board, row, col, player):
    # Check horizontal
    for c in range(col + 1, 3):
        if board[row][c]!= player:
            break
    else:
        return True
    
    # Check vertical
    for r in range(row + 1, 3):
        if board[r][col]!= player:
            break
    else:
        return True
    
    # Check diagonal (top-left to bottom-right)
    if row == col:
        for d in range(1, 3):
            if board[d][d]!= player:
                break
        else:
            return True
    
    # Check diagonal (bottom-left to top-right)
    if row + col == 2:
        for d in range(1, 3):
            if board[2-d][d]!= player:
                break
        else:
            return True
    
    return False

# Get a random non-winning move
move = get_random_non_winning_move(board)
print(f"Move: {move}")
```

This code randomly selects a non-winning move and checks if it leads to a win. If not, it returns the selected move. Since we don't know which specific move will work, we'll use this approach to find a suitable move.

However, without knowing the exact outcome of the previous moves, we cannot definitively predict the optimal move. The provided solution assumes a random selection of a non-winning move, but in practice, you'd need more information about past moves to make an informed decision.
