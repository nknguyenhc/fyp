def get_next_move(board):
    # Determine the next player (O or X)
    next_player = 'O' if 'X' in board else 'X'
    
    # Find the next empty cell
    for i in range(3):
        for j in range(3):
            if board[i][j] == '-':
                return f"{i+1}{j+1}"  # Return the cell number (1-based)
    
    # If no empty cells are found, the game is a tie
    return "Tie"

